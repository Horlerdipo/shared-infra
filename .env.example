MYSQL_VERSION=9.7
MYSQL_DB_USERNAME=root
MYSQL_DB_PASSWORD=random-mysql-password
MYSQL_DB_PORT=3306

POSTGRES_VERSION=18
POSTGRES_DB_USERNAME=postgres
POSTGRES_DB_PASSWORD=random-postgres-password
POSTGRES_DB_PORT=5432

REDIS_VERSION=latest
REDIS_DB_PASSWORD=random-redis-password
REDIS_DB_PORT=6379

# TLS (Let's Encrypt)

DOMAIN_NAME="domain-name-without-prefix (e.g google.com not mail.google.com or https://google.com)"
TLS_EMAIL_ADDRESS=

# Traefik Dashboard Authentication (Required for Production)
# Remember to escape $ characters by doubling them (e.g., $ becomes $$)
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD_HASH=
TRAEFIK_VERSION=latest